generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Feedback {
  id             String   @id @default(cuid())
  departmentId   String
  departmentName String
  overallRating  Int
  comment        String?
  answers        Json
  createdAt      DateTime @default(now())
}